<?xml version="1.0" encoding="utf-8"?>
<!--
  DB-World native video player layout.
  • Brightness indicator – left edge, vertical fill bar
  • Volume indicator     – right edge, vertical fill bar
  • Episode panel        – right-side overlay, slides in from end
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- ── Video surface ────────────────────────────────────────────────────── -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/player_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="false"
        app:resize_mode="fit"
        app:surface_type="surface_view"
        app:show_subtitle_button="false" />

    <!-- ── Controls container (auto-hides) ──────────────────────────────────── -->
    <FrameLayout
        android:id="@+id/controls_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Top gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@drawable/gradient_top" />

        <!-- Bottom gradient -->
        <View
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom" />

        <!-- ── Top bar ──────────────────────────────────────────────────────── -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:paddingStart="4dp"
            android:paddingEnd="4dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_player_back" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/btn_back"
                android:layout_toStartOf="@+id/btn_episodes"
                android:layout_centerVertical="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:paddingStart="8dp"
                android:paddingEnd="4dp"
                android:shadowColor="@android:color/black"
                android:shadowRadius="3"
                android:textColor="@android:color/white"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Episodes button -->
            <ImageButton
                android:id="@+id/btn_episodes"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_toStartOf="@+id/btn_pip"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_player_episodes"
                android:contentDescription="Episodes"
                android:visibility="gone" />

            <ImageButton
                android:id="@+id/btn_pip"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_toStartOf="@+id/btn_lock"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_player_pip"
                android:contentDescription="Picture-in-Picture" />

            <ImageButton
                android:id="@+id/btn_lock"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_player_lock"
                android:contentDescription="Lock screen" />
        </RelativeLayout>

        <!-- ── Centre seek-flash labels + play/pause ───────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_seek_left"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="◀◀  10 s"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:visibility="gone" />
            </FrameLayout>

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="#55000000"
                android:src="@drawable/ic_player_pause"
                android:contentDescription="Play / Pause" />

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center">
                <TextView
                    android:id="@+id/tv_seek_right"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="10 s  ▶▶"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!-- ── Bottom bar ────────────────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/bottom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressBackgroundTint="#66FFFFFF"
                android:progressTint="@android:color/white"
                android:thumbTint="@android:color/white"
                android:secondaryProgressTint="#88FFFFFF" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <TextView
                    android:id="@+id/tv_time"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00 / 0:00"
                    android:textColor="@android:color/white"
                    android:textSize="12sp" />

                <!-- Combined Audio + Subtitle -->
                <ImageButton
                    android:id="@+id/btn_tracks"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_player_audio"
                    android:contentDescription="Audio &amp; Subtitles" />

                <!-- Playback speed -->
                <TextView
                    android:id="@+id/btn_speed"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:text="1×"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:contentDescription="Playback speed" />
            </LinearLayout>
        </LinearLayout>

    </FrameLayout><!-- end controls_container -->

    <!-- ── Left: Brightness vertical indicator ─────────────────────────────── -->
    <LinearLayout
        android:id="@+id/brightness_indicator"
        android:layout_width="44dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|start"
        android:layout_marginStart="16dp"
        android:background="#CC000000"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_day"
            android:tint="@android:color/white" />

        <!-- Track (track = dark bg + white fill from bottom) -->
        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#44FFFFFF">

            <View
                android:id="@+id/brightness_fill"
                android:layout_width="match_parent"
                android:layout_height="50%"
                android:layout_gravity="bottom"
                android:background="@android:color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/brightness_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@android:color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- ── Right: Volume vertical indicator ────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/volume_indicator"
        android:layout_width="44dp"
        android:layout_height="200dp"
        android:layout_gravity="center_vertical|end"
        android:layout_marginEnd="16dp"
        android:background="#CC000000"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="8dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_lock_silent_mode_off"
            android:tint="@android:color/white" />

        <FrameLayout
            android:layout_width="6dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#44FFFFFF">

            <View
                android:id="@+id/volume_fill"
                android:layout_width="match_parent"
                android:layout_height="50%"
                android:layout_gravity="bottom"
                android:background="@android:color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/volume_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="50%"
            android:textColor="@android:color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- ── Episode panel (slides in from right) ─────────────────────────────── -->
    <FrameLayout
        android:id="@+id/episode_panel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="#E6141414"
        android:elevation="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingTop="56dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Episodes"
                    android:textColor="@android:color/white"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_close_episodes"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="@android:color/white"
                    android:contentDescription="Close" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#33FFFFFF" />

            <!-- Scrollable episode list -->
            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:id="@+id/episode_list_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingTop="8dp"
                    android:paddingBottom="16dp" />
            </ScrollView>
        </LinearLayout>
    </FrameLayout>

    <!-- ── Lock overlay (blocks all touches, shows unlock button) ──────────── -->
    <FrameLayout
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/btn_unlock"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="20dp"
            android:background="#66000000"
            android:src="@drawable/ic_player_unlock"
            android:contentDescription="Unlock" />
    </FrameLayout>

    <!-- ── Buffering spinner ────────────────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/buffering_indicator"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:layout_gravity="center"
        android:indeterminate="true"
        android:indeterminateTint="@android:color/white"
        android:visibility="gone" />

</FrameLayout>
