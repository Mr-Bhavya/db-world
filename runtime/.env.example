# Frontend environment variables — copy to .env.local / .env.production and fill in real values
# DO NOT commit .env.local or .env.production to git

# Base URL of the backend API.
# - Leave blank in dev if you proxy /api via Vite to a local backend.
# - Set to the API host in staging/prod, e.g. https://api.db-world.in
# - When unset, the app falls back to api.<frontend-host> for the known
#   production frontend domain, so prod still works without this var.
VITE_API_BASE_URL=https://api.db-world.in
