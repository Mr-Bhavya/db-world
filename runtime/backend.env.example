# Backend environment variables — copy to backend.env and fill in real values
# DO NOT commit backend.env to git

DB_HOST=localhost
DB_PORT=3306
DB_NAME=db_world
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_MIN=2
DB_POOL_MAX=10

JWT_SECRET=your_jwt_secret_hex
JWT_PRIVATE_KEY=your_rsa_private_key_base64
JWT_PUBLIC_KEY=your_rsa_public_key_base64

JASYPT_PASSWORD=your_jasypt_encryption_password

ARIA2_RPC_URL=http://localhost:6800/jsonrpc
ARIA2_WS_URL=ws://localhost:6800/jsonrpc
ARIA2_SECRET=your_aria2_rpc_secret

REDIS_HOST=localhost
REDIS_PORT=6379

SERVER_PORT=9000

TMDB_API_KEY=your_tmdb_api_key
TMDB_ACCESS_TOKEN=your_tmdb_access_token
TMDB_BEARER_TOKEN=your_tmdb_bearer_token

# OpenWeatherMap key — used by /api/weather. Server-side only; never expose to the browser.
OPENWEATHER_API_KEY=your_openweather_api_key
