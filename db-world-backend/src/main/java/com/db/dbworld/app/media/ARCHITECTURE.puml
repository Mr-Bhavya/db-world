title db-world · app.media — Technical Architecture\n(Ingestion Pipeline · MediaInfo · TMDB Enrichment · MySQL Storage)

' ════════════════════════════════════════════════════════════════════════════
' PACKAGE: app.media.ingestion
' ════════════════════════════════════════════════════════════════════════════
package "app.media.ingestion" #EEF5FF {

    package "controller" #DDEEFF {
        class IngestionController <<RestController>> {
            POST   /api/ingestion
            PUT    /{jobId}/cancel
            PUT    /{jobId}/pause
            PUT    /{jobId}/resume
            POST   /{jobId}/rerun
            DELETE /{jobId}
            GET    /status
            GET    /{jobId}/report
            GET    /history
            GET    /history/{jobId}
            GET    /history/record/{recordId}
        }
    }

    package "pipeline" #DDEEFF {
        interface IngestionPipeline {
            + start(request): String
        }
        class DefaultIngestionPipeline <<Component>> {
            - sourceHandlers: List<SourceHandler>
            - downloadStrategies: List<DownloadStrategy>
            - processingStrategies: List<ProcessingStrategy>
            - jobStore: IngestionJobStore
            - repository: IngestionRepository
            + start(request): String
        }
        enum PipelineStepType {
            SOURCE_RESOLUTION
            DOWNLOAD
            EXTRACTION
            PROCESSING
            COMPLETE
        }
    }

    package "store" #DDEEFF {
        class IngestionJobStore <<Component>> {
            - jobs: ConcurrentHashMap<String, JobMeta>
            + register(jobId, request)
            + setGid(jobId, gid)
            + setCancelAction(jobId, fn)
            + setPauseAction(jobId, fn)
            + setResumeAction(jobId, fn)
            + executeCancelAction(jobId)
            + executePauseAction(jobId)
            + executeResumeAction(jobId)
            + getGid(jobId): Optional<String>
            + getRequest(jobId): Optional<IngestionRequest>
            + getSourceType(jobId): String
            + remove(jobId)
            == inner: JobMeta ==
            gid: AtomicReference<String>
            request: IngestionRequest
            sourceType: SourceType
            cancelFn, pauseFn, resumeFn: Runnable
        }
    }

    package "spi" #DDEEFF {
        interface SourceHandler {
            + supports(uri): boolean
            + resolve(uri): SourceMetadata
        }
        interface DownloadStrategy {
            + supports(source): boolean
            + download(ctx): DownloadResult
            + cancel(jobId)
        }
        interface ProcessingStrategy {
            + supports(ctx): boolean
            + process(ctx): ProcessingResult
        }
        interface PipelineStep {
            + execute(ctx)
        }
    }

    package "download" #DDEEFF {
        class YtDlpDownloadStrategy <<Component>> {
            Order = 1
            + supports: YOUTUBE
            - cancellationFlag: AtomicBoolean
        }
        class Aria2DownloadStrategy <<Component>> {
            Order = 2
            + supports: HTTP, TORRENT
            - jobStore: IngestionJobStore
            registers GID after addUri()
            poll loop handles PAUSED status
        }
    }

    package "processing.strategy" #DDEEFF {
        class ExtractionProcessingStrategy <<Component>> {
            Order = 1
            Handles .zip, .rar, .7z archives
            Uses 7-zip process
        }
        class FfmpegProcessingStrategy <<Component>> {
            Order = 10
            1. Move temp → final dir
            2. TMDB enrichment (cover + naming)
            3. Collect & persist MediaInfo
        }
    }

    package "processing.fs" #DDEEFF {
        interface FileStorageService {
            + resolveFinalDir(ctx): Path
        }
        class DefaultFileStorageService <<Component>>
    }

    package "persistence" #DDEEFF {
        interface IngestionRepository {
            + save(context)
        }
        class NoOpIngestionRepository <<Repository>>
        class JpaIngestionRepository <<Repository>> <<Primary>> {
            Persists complete snapshot at completion
            Converts SourceType String → enum
        }
    }

    package "repository" #DDEEFF {
        interface IngestionJobRepository <<JpaRepository>> {
            findByStatus(status)
            findByRecordId(recordId)
            findBySourceType(type)
            findByFolderName(name)
        }
    }

    package "entity" #DDEEFF {
        class IngestionJobEntity <<Entity>> {
            @Id jobId: String (UUID)
            --
            @Enumerated status: MirrorStatus
            @Enumerated step: PipelineStepType
            @Enumerated sourceType: SourceType
            --
            uri: String
            folderName: String
            fileName: String
            gid: String        [Aria2 GID, null for yt-dlp]
            downloadedBytes: Long
            totalBytes: Long
            failReason: String
            --
            mediaInfoJson: JSON  [MySQL JSON type]
            recordId: Long
            seasonNumber: Integer
            episodeNumber: Integer
            --
            startedAt: Instant  [@CreatedDate]
            updatedAt: Instant  [@LastModifiedDate]
            completedAt: Instant
        }
    }

    package "enums" #DDEEFF {
        enum SourceType {
            YOUTUBE
            HTTP
            TORRENT
            UNKNOWN
        }
    }

    package "model" #DDEEFF {
        class IngestionRequest {
            uri, uris: String / List<String>
            folderName, fileName: String
            username, password: String
            urlProtected, extract, rename, onlyAudio: boolean
            extractPassword: String
            videoITag, audioITag: String
            expectedSize: Long
            recordId: Long
            season: Integer
            episode: Integer
        }
        class IngestionContext {
            jobId: String
            recordId: Long
            request: IngestionRequest
            source: SourceMetadata
            download: DownloadResult
            processing: ProcessingResult
            status: MirrorStatus
            currentStep: PipelineStepType
            cancellationFlag: AtomicBoolean
            logCollector: LogCollector
        }
        class SourceMetadata {
            uri, type: String
            attributes: Map<String,Object>
        }
        class DownloadResult {
            filePath: Path
            fileName: String
            gid: String
            size: Long
            success: boolean
            errorMessage: String
        }
        class ProcessingResult {
            finalFile: Path
            success: boolean
            errorMessage: String
            mediaInfo: Map<String,Object>
        }
    }

    package "tracking" #DDEEFF {
        interface TrackingService {
            + updateStatus(jobId, status)
            + getAll(): Map
            + getHtmlReport(jobId): String
        }
        class MirrorStateMachine
        class ProgressSnapshot
        enum MirrorStatus {
            QUEUED
            STARTED
            DOWNLOADING
            PAUSED
            PROCESSING
            SUCCESS
            FAILED
            CANCELLED
        }
    }
}

' ════════════════════════════════════════════════════════════════════════════
' PACKAGE: app.media.enrichment
' ════════════════════════════════════════════════════════════════════════════
package "app.media.enrichment" #FFF5EE {
    interface TmdbMediaEnrichmentService {
        + enrich(inputFile, recordId, season, episode, jobId): Path
    }
    class TmdbMediaEnrichmentServiceImpl <<Service>> <<Transactional>> {
        TMDB_IMAGE_BASE = "https://image.tmdb.org/t/p/original"
        --
        - recordRepository: RecordRepository
        - processExecutor: ProcessExecutor
        - httpClient: HttpClient
        --
        1. Load RecordEntity → TmdbEntity
        2. Resolve episode info (series only)
        3. Download poster/still from TMDB CDN
        4. Run FFmpeg: embed cover art + metadata
        5. Rename file (series: Title.SXXEXX.EpName.ext)
        6. Delete temp poster + original input
        --
        - resolveEpisode(tvSeries, season, ep)
        - downloadImage(posterPath, jobId): Path
        - runFfmpegEnrich(input, poster, output, title, jobId)
        - resolveOutputPath(input, seriesTitle, season, ep, epName): Path
        - safeName(name): String
    }
}

note right of TmdbMediaEnrichmentServiceImpl
    FFmpeg command:
    ffmpeg -y -i input.mkv -i poster.jpg
           -map 0 -map 1 -c copy
           -disposition:v:1 attached_pic
           -metadata:s:v:1 mimetype=image/jpeg
           -metadata title="&#123;EpisodeName&#125;"
           output.mkv
    --
    Series filename pattern:
    &#123;SafeTitle&#125;.S&#123;SS&#125;E&#123;EE&#125;.&#123;SafeEpName&#125;.&#123;ext&#125;
    Movies: &#123;name&#125;_enriched.&#123;ext&#125;
    (FFmpeg cannot edit files in-place)
end note

