' PACKAGE: app.media.info
' ════════════════════════════════════════════════════════════════════════════
package "app.media.info" #F0FFF0 {

    package "controller" #DDFFD5 {
        class MediaInfoController <<RestController>> {
            GET    /api/media/info/record/{recordId}
            GET    /api/media/info/{id}
            POST   /api/media/info/scan
            POST   /api/media/info/{id}/rescan
            GET    /api/media/info/raw
            DELETE /api/media/info/path
            DELETE /api/media/info/record/{recordId}
        }
    }

    package "service" #DDFFD5 {
        interface MediaInfoService {
            + collectAndPersist(path, recordId, jobId): MediaFileDto
            + rescan(id): MediaFileDto
            + getByRecordId(id): List<MediaFileDto>
            + getById(id): Optional<MediaFileDto>
            + getByFilePath(path): Optional<MediaFileDto>
            + deleteByFilePath(path)
            + deleteByRecordId(id)
            + getRawJson(path): String
        }
        class MediaInfoServiceImpl <<Service>> {
            Uses: mediainfo --output=JSON &#123;path&#125;
            Parses JSON → TrackEntity hierarchy
            Deletes existing before re-persisting
        }
    }

    package "entity" #DDFFD5 {
        class MediaFileEntity <<Entity>> {
            @Id id: String (UUID)
            record: RecordEntity  [@ManyToOne LAZY]
            fileName: String
            filePath: String [UNIQUE with record_id]
            fileSize: Long
            mimeType: String
            ingestionJobId: String
            rawMediaInfoJson: JSON  [MySQL JSON type]
            createdAt: Instant  [@CreatedDate]
            updatedAt: Instant  [@LastModifiedDate]
            tracks: List<TrackEntity>  [@OneToMany CascadeALL]
        }

        abstract class TrackEntity <<Entity>> {
            @Id id: Long  [AUTO]
            mediaFile: MediaFileEntity  [@ManyToOne]
            trackType: String  [discriminator]
            streamOrder: Integer
            extraJson: JSON  [MySQL JSON type — full raw data]
        }

        class GeneralTrackEntity <<Entity>> {
            discriminator = "General"
            format, formatVersion: String
            fileSize, duration: Long  [duration in ms]
            overallBitRate: Long
            videoCount, audioCount, textCount: Integer
            fileExtension, title: String
            encodedApplication, encodedDate: String
        }
        class VideoTrackEntity <<Entity>> {
            discriminator = "Video"
            format, codecId, profile: String
            width, height: Integer
            displayAspectRatio, frameRate: String
            bitRate, streamSize, duration: Long
            bitDepth: Integer
            colorSpace, hdrFormat, hdrFormatCompatibility: String
            defaultTrack, forced: String
        }
        class AudioTrackEntity <<Entity>> {
            discriminator = "Audio"
            format, formatCommercial, codecId: String
            language, title: String
            channels: Integer
            channelLayout: String
            samplingRate, bitRate, streamSize, duration: Long
            bitRateMode, compressionMode: String
            defaultTrack, forced: String
        }
        class TextTrackEntity <<Entity>> {
            discriminator = "Text"
            format, codecId, language, title: String
            streamSize, frameCount: Long
            frameRate: String
            defaultTrack, forced: String
        }
        class ImageTrackEntity <<Entity>> {
            discriminator = "Image"
            format: String  [JPEG, PNG]
            width, height: Integer
            title: String  [Cover, Thumbnail]
            mimeType: String  [image/jpeg, image/png]
            streamSize: Long
            source: String  [EMBEDDED | TMDB]
            tmdbPosterPath: String  [/abc.jpg — set when source=TMDB]
        }
    }

    package "repository" #DDFFD5 {
        interface MediaFileRepository <<JpaRepository>> {
            @EntityGraph(tracks) findByRecord_Id(id)
            @EntityGraph(tracks) findByFilePath(path)
            deleteByFilePath(path)
            deleteAllByRecord_Id(id)
        }
    }

    package "dto" #DDFFD5 {
        class MediaFileDto <<DTO>> {
            @Builder @JsonInclude(NON_NULL)
            id, recordId, fileName, filePath: String
            fileSize: Long
            mimeType, ingestionJobId: String
            createdAt, updatedAt: Instant
            tracks: List<TrackDto>
            --
            getGeneralTrack(): TrackDto
            getPrimaryVideoTrack(): TrackDto
            getPrimaryAudioTrack(): TrackDto
        }
        class TrackDto <<DTO>> {
            @Builder @JsonInclude(NON_NULL)
            type, format: String
            streamOrder: Integer
            fileSize, duration, overallBitRate: Long
            videoCount, audioCount, textCount: Integer
            width, height: Integer
            frameRate, colorSpace, hdrFormat: String
            bitRate: Long
            bitDepth: Integer
            language, title: String
            channels: Integer
            samplingRate: Long
            defaultTrack, forced: String
            mimeType, source, tmdbPosterPath: String  [Image]
            extra: Map<String,Object>
        }
    }
}

