' ════════════════════════════════════════════════════════════════════════════
' DATABASE TABLES (MySQL, new_db_world schema)
' ════════════════════════════════════════════════════════════════════════════
package "MySQL · new_db_world schema" #F8F0FF {
    class "ingestion_jobs" as DB_JOBS <<Database>> {
        job_id VARCHAR(36) PK
        status VARCHAR(20)       -- MirrorStatus enum
        step VARCHAR(20)         -- PipelineStepType enum
        source_type VARCHAR(20)  -- SourceType enum
        uri VARCHAR(2000)
        folder_name VARCHAR(500)
        file_name VARCHAR(500)
        gid VARCHAR(50)          -- Aria2 GID (NULL for yt-dlp)
        downloaded_bytes BIGINT
        total_bytes BIGINT
        fail_reason VARCHAR(1000)
        media_info_json JSON     -- MySQL JSON type
        record_id BIGINT
        season_number INT
        episode_number INT
        started_at DATETIME      -- @CreatedDate
        updated_at DATETIME      -- @LastModifiedDate
        completed_at DATETIME
    }
    class "media_files" as DB_FILES <<Database>> {
        id VARCHAR(36) PK        -- UUID
        record_id BIGINT FK      -- → records.id
        file_name VARCHAR(1000)
        file_path VARCHAR(1000)
        file_size BIGINT
        mime_type VARCHAR(100)
        ingestion_job_id VARCHAR(36)
        raw_media_info_json JSON -- MySQL JSON type
        created_at DATETIME
        updated_at DATETIME
        UQ(record_id, file_path)
    }
    class "media_tracks" as DB_TRACKS <<Database>> {
        id BIGINT PK AUTO
        media_file_id VARCHAR(36) FK -- → media_files.id
        track_type VARCHAR(31)        -- SINGLE_TABLE discriminator
        stream_order INT
        extra_json JSON               -- MySQL JSON type (full raw track data)
        -- General track columns --
        gen_format, gen_format_version, gen_file_ext...
        -- Video track columns --
        vid_format, vid_codec_id, vid_width, vid_height...
        vid_hdr_format, vid_hdr_format_compatibility...
        -- Audio track columns --
        aud_format, aud_language, aud_channels, aud_sampling_rate...
        -- Text track columns --
        txt_format, txt_language, txt_frame_rate...
        -- Image track columns --
        img_format, img_width, img_height, img_title
        img_mime_type, img_stream_size
        img_source VARCHAR(20)        -- EMBEDDED | TMDB
        img_tmdb_poster_path VARCHAR(300)
    }
}

