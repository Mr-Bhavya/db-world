<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" shutdownHook="disable">
    <!-- Define Properties -->
        <Properties>
            <Property name="CONSOLE_LOG_PATTERN">
                %style{%d{dd/MM/yyyy|HH:mm:ss.SSS a}{IST}{ISO8601}}{magenta} [%highlight{%-5level}] %style{%C{2.}.%M}{yellow}%style{(line:%L)}{blue}: %msg%n%throwable
            </Property>
            <Property name="LOG_FILE_PATTERN">
                %d{dd/MM/yyyy HH:mm:ss.SSS a}{IST}{ISO8601} [%-5level] %C{2.}.%M(line:%L): %msg%n%throwable
            </Property>
            <property name="LOG_FILE_PATH">
                /app/db_world/logs
            </property>
        </Properties>

    <!-- Define Appenders -->
    <Appenders>
        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT" follow="true">
            <PatternLayout pattern="${CONSOLE_LOG_PATTERN}" disableAnsi="false"/>
        </Console>

        <!-- Main Log File -->
        <RollingFile name="MainFile" fileName="${LOG_FILE_PATH}/dbworld.log" filePattern="${LOG_FILE_PATH}/dbworld-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="${LOG_FILE_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/> <!-- Rotate daily -->
            </Policies>
            <DefaultRolloverStrategy max="7"> <!-- Delete logs older than 1 week -->
                <Delete basePath="${LOG_FILE_PATH}" maxDepth="1">
                    <IfFileName glob="dbworld-*.log" />
                    <IfLastModified age="7d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- Info Log File -->
        <RollingFile name="InfoFile" fileName="${LOG_FILE_PATH}/dbworld-info.log" filePattern="${LOG_FILE_PATH}/dbworld-info-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="${LOG_FILE_PATTERN}"/>
            <Filters>
                <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/> <!-- Rotate daily -->
            </Policies>
            <DefaultRolloverStrategy max="7"> <!-- Delete logs older than 1 week -->
                <Delete basePath="${LOG_FILE_PATH}" maxDepth="1">
                    <IfFileName glob="dbworld-info-*.log" />
                    <IfLastModified age="7d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- Warn Log File -->
        <RollingFile name="WarnFile" fileName="${LOG_FILE_PATH}/dbworld-warn.log" filePattern="${LOG_FILE_PATH}/dbworld-warn-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="${LOG_FILE_PATTERN}"/>
            <Filters>
                <ThresholdFilter level="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/> <!-- Rotate daily -->
            </Policies>
            <DefaultRolloverStrategy max="7"> <!-- Delete logs older than 1 week -->
                <Delete basePath="${LOG_FILE_PATH}" maxDepth="1">
                    <IfFileName glob="dbworld-warn-*.log" />
                    <IfLastModified age="7d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- Error Log File -->
        <RollingFile name="ErrorFile" fileName="${LOG_FILE_PATH}/dbworld-error.log" filePattern="${LOG_FILE_PATH}/dbworld-error-%d{yyyy-MM-dd}.log">
            <PatternLayout pattern="${LOG_FILE_PATTERN}"/>
            <Filters>
                <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
            </Filters>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/> <!-- Rotate daily -->
            </Policies>
            <DefaultRolloverStrategy max="7"> <!-- Delete logs older than 1 week -->
                <Delete basePath="${LOG_FILE_PATH}" maxDepth="1">
                    <IfFileName glob="dbworld-error-*.log" />
                    <IfLastModified age="7d" />
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>
    </Appenders>

    <!-- Define Loggers -->
    <Loggers>
        <!-- Root Logger -->
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="MainFile"/>
            <AppenderRef ref="InfoFile"/>
            <AppenderRef ref="WarnFile"/>
            <AppenderRef ref="ErrorFile"/>
        </Root>
    </Loggers>
</Configuration>


