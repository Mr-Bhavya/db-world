<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" shutdownHook="disable">

    <Properties>
        <!-- Define Active Profile -->
        <Property name="ACTIVE_PROFILE">${sys:spring.profiles.active:-prod}</Property>

        <!-- Define both paths as separate properties -->
        <Property name="LOG_BASE_PATH_LOCAL">D:/home/dbworld_admin/ext_hdisk/dbworld/logs</Property>
        <Property name="LOG_BASE_PATH_PROD">/app/db_world/logs</Property>

        <!-- Use direct property reference without ternary in path -->
        <Property name="LOG_BASE_PATH">${sys:LOG_BASE_PATH}</Property>

        <!-- Remove duplicate LOG_FILE_PATH definition -->
        <Property name="LOG_FILE_PATH">${LOG_BASE_PATH_PROD}</Property>

        <!-- Retain logs for X days -->
        <Property name="LOG_RETENTION_DAYS">7</Property>

        <!-- Console output format -->
        <Property name="CONSOLE_LOG_PATTERN">
            %style{%d{dd/MM/yyyy HH:mm:ss.SSS a}{IST}}{magenta} [%highlight{%-5level}] %style{%C{1}.%M():%L}{yellow} %replace{%replace{%replace{
            [user=%X{user}] [method=%X{method}] [uri=%X{uri}] [query=%X{query}] [status=%X{status}] [duration=%X{duration}]
            }{(\[\w+=(null|N/A|)\])}{}}{(\[\w+=\])}{}}{(\s\s+)}{} %msg%n%throwable
        </Property>

        <!-- File output format -->
        <Property name="FILE_LOG_PATTERN">
            %d{dd/MM/yyyy HH:mm:ss.SSS a}{IST} [%-5level] %C{1}.%M():%L %replace{%replace{%replace{
            [user=%X{user}] [method=%X{method}] [uri=%X{uri}] [query=%X{query}] [status=%X{status}] [duration=%X{duration}]
            }{(\[\w+=(null|N/A|)\])}{}}{(\[\w+=\])}{}}{(\s\s+)}{} %msg%n%throwable
        </Property>

        <!-- Shared pattern for base usage -->
        <Property name="BASE_LOG_PATTERN">${FILE_LOG_PATTERN}</Property>
    </Properties>

    <Appenders>

        <!-- Console Appender -->
        <Console name="Console" target="SYSTEM_OUT" follow="true">
            <PatternLayout pattern="${CONSOLE_LOG_PATTERN}" disableAnsi="false"/>
        </Console>

        <!-- Main File Appender -->
        <RollingFile name="MainFile"
                     fileName="${LOG_FILE_PATH}/dbworld.log"
                     filePattern="${LOG_FILE_PATH}/archived/dbworld-%d{yyyy-MM-dd}-%i.log">
            <PatternLayout pattern="${BASE_LOG_PATTERN}"/>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="${LOG_RETENTION_DAYS}">
                <Delete basePath="${LOG_FILE_PATH}/archived" maxDepth="1">
                    <IfFileName glob="dbworld-*.log"/>
                    <IfLastModified age="${LOG_RETENTION_DAYS}d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- JSON Log Appender -->
        <RollingFile name="JsonFile"
                     fileName="${LOG_FILE_PATH}/dbworld.json"
                     filePattern="${LOG_FILE_PATH}/archived/dbworld-%d{yyyy-MM-dd}-%i.json">
            <JsonLayout compact="true" eventEol="true" includeStacktrace="true">
                <KeyValuePair key="user" value="$${ctx:user:-null}"/>
                <KeyValuePair key="method" value="$${ctx:method:-null}"/>
                <KeyValuePair key="uri" value="$${ctx:uri:-null}"/>
                <KeyValuePair key="query" value="$${ctx:query:-null}"/>
                <KeyValuePair key="status" value="$${ctx:status:-null}"/>
                <KeyValuePair key="duration" value="$${ctx:duration:-null}"/>
            </JsonLayout>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="100 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="${LOG_RETENTION_DAYS}">
                <Delete basePath="${LOG_FILE_PATH}/archived" maxDepth="1">
                    <IfFileName glob="dbworld-*.json"/>
                    <IfLastModified age="${LOG_RETENTION_DAYS}d"/>
                </Delete>
            </DefaultRolloverStrategy>
        </RollingFile>

        <!-- Routing Appender for per-level log files -->
        <Routing name="LevelBasedRouting">
            <Routes pattern="$${sys:logLevel}">
                <Route key="DEBUG">
                    <RollingFile name="DebugFile"
                                 fileName="${LOG_FILE_PATH}/dbworld-debug.log"
                                 filePattern="${LOG_FILE_PATH}/archived/dbworld-debug-%d{yyyy-MM-dd}-%i.log">
                        <PatternLayout pattern="${BASE_LOG_PATTERN}"/>
                        <Filters>
                            <ThresholdFilter level="DEBUG" onMatch="ACCEPT" onMismatch="DENY"/>
                        </Filters>
                        <Policies>
                            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                        </Policies>
                    </RollingFile>
                </Route>
                <Route key="INFO">
                    <RollingFile name="InfoFile"
                                 fileName="${LOG_FILE_PATH}/dbworld-info.log"
                                 filePattern="${LOG_FILE_PATH}/archived/dbworld-info-%d{yyyy-MM-dd}-%i.log">
                        <PatternLayout pattern="${BASE_LOG_PATTERN}"/>
                        <Filters>
                            <ThresholdFilter level="INFO" onMatch="ACCEPT" onMismatch="DENY"/>
                        </Filters>
                        <Policies>
                            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                        </Policies>
                    </RollingFile>
                </Route>
                <Route key="WARN">
                    <RollingFile name="WarnFile"
                                 fileName="${LOG_FILE_PATH}/dbworld-warn.log"
                                 filePattern="${LOG_FILE_PATH}/archived/dbworld-warn-%d{yyyy-MM-dd}-%i.log">
                        <PatternLayout pattern="${BASE_LOG_PATTERN}"/>
                        <Filters>
                            <ThresholdFilter level="WARN" onMatch="ACCEPT" onMismatch="DENY"/>
                        </Filters>
                        <Policies>
                            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                        </Policies>
                    </RollingFile>
                </Route>
                <Route key="ERROR">
                    <RollingFile name="ErrorFile"
                                 fileName="${LOG_FILE_PATH}/dbworld-error.log"
                                 filePattern="${LOG_FILE_PATH}/archived/dbworld-error-%d{yyyy-MM-dd}-%i.log">
                        <PatternLayout pattern="${BASE_LOG_PATTERN}"/>
                        <Filters>
                            <ThresholdFilter level="ERROR" onMatch="ACCEPT" onMismatch="DENY"/>
                        </Filters>
                        <Policies>
                            <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                        </Policies>
                    </RollingFile>
                </Route>
            </Routes>
        </Routing>

    </Appenders>

    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="MainFile"/>
            <AppenderRef ref="JsonFile"/>
            <AppenderRef ref="LevelBasedRouting"/>
        </Root>
    </Loggers>
</Configuration>
